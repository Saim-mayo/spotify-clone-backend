# .env.example — copy this to .env in the project root and fill in real values.
# Never commit the real .env file (it's already in .gitignore — keep it that way).

# ==========================
# SERVER
# ==========================
PORT=3000
NODE_ENV=development
# Use "production" on your deployed host — this also turns on rate limiting (see src/app.js)

# ==========================
# DATABASE
# ==========================
# Must be a replica set — the app uses MongoDB transactions (see src/utils/mongoTransaction.js).
# Local dev: mongodb://localhost:27017/spotify-clone?replicaSet=rs0
# MongoDB Atlas free tier (M0) is a replica set by default, so an Atlas URI works as-is.
MONGO_URI=mongodb://localhost:27017/spotify-clone?replicaSet=rs0

# ==========================
# AUTH / TOKENS
# ==========================
# Signs short-lived access tokens (JWT). Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=

# Access token lifetime
ACCESS_TOKEN_EXPIRES=15m

# Refresh tokens are opaque (not JWTs) — random bytes hashed with HMAC and stored
# in Mongo (see src/utils/tokenStore.js). This is the secret used for that HMAC.
# Generate with: openssl rand -hex 64
REFRESH_TOKEN_HMAC_SECRET=

# Note: refresh token expiry is currently hardcoded to 30 days in tokenStore.js,
# not read from an env var — no REFRESH_TOKEN_EXPIRES var is needed here.

# ==========================
# IMAGEKIT (file/image storage)
# ==========================
IMAGE_KIT_PUBLIC_KEY=
IMAGE_KIT_PRIVATE_KEY=
IMAGE_KIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ==========================
# STRIPE (payments)
# ==========================
# Use TEST mode keys (sk_test_...) for local dev and portfolio/demo deploys.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Generated per-webhook-endpoint in the Stripe dashboard. A new endpoint URL
# (e.g. after deploying) gets its own whsec_ value — copy the one that matches
# the endpoint you actually registered under Developers > Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Where Stripe Checkout redirects the user after payment. Point these at your
# frontend's routes once the frontend exists.
CLIENT_URL=http://localhost:5173
STRIPE_SUCCESS_URL=http://localhost:5173/payment-success
STRIPE_CANCEL_URL=http://localhost:5173/payment-cancel

# Optional — only "true" after Stripe Tax (origin address + tax registrations)
# is configured in the Dashboard. Leave false/unset until then, or Checkout
# session creation will fail. See src/services/stripe.service.js.
STRIPE_AUTOMATIC_TAX=false

# ---------------------------------------------------------------
# PLAN CATALOG (Stripe -> Mongo sync, see src/config/plans.js)
# ---------------------------------------------------------------
# No plan/product IDs are stored here. Plan tiers, pricing, and features live
# in the `Plan` collection in Mongo, kept in sync with Stripe via webhooks
# (product.created/updated, price.created/updated — see
# src/routes/webhook.routes.js and src/services/planSync.service.js).
# Editing a Product in the Stripe Dashboard updates the app automatically,
# no redeploy and no env var to add.
#
# First-time / fresh environment: run `node src/scripts/syncPlans.js` after
# creating at least one Product in Stripe. It calls stripe.products.list()
# and backfills every product Stripe returns.
#
# Optional one-time metadata per Stripe Product (Dashboard):
# - metadata.planKey        — internal key used in API payloads/URLs
#                              (default: slugified from the Product name)
# - metadata.dailyPlayLimit — number, or "unlimited"/"null" (default: unlimited)
# - metadata.canDownload    — "true"/"false" (default: false)
# - metadata.maxDownloads   — number, or "unlimited"/"null" (default: 0)
# - metadata.adFree         — "true"/"false" (default: false)

# ==========================
# GOOGLE OAUTH
# ==========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an "Authorized redirect URI" configured in Google Cloud
# Console for this OAuth client, and must be reachable from the public internet
# (a tunnel URL like ngrok only works while that tunnel session is running —
# swap to your real deployed URL before/after deploy).
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ==========================
# ADMIN SEED (used by src/scripts/seedAdmin.js)
# ==========================
# Only used once, to create the first admin user. Use a real random password,
# not a placeholder — this account has admin.controller.js access.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=

# ==========================
# CORS
# ==========================
# Comma-separated list of origins allowed to call this API with credentials
# (see src/app.js). Include your frontend's dev URL and, once deployed, its
# production URL. Falls back to http://localhost:5173 if unset.
ALLOWED_ORIGINS=http://localhost:5173
